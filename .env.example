# Copy this file to `.env` and adjust as needed.
# None of these values are secret. Credentials (a Bluesky App Password) are
# never stored here — they are only entered at publish time.

# Public hostname the service is served at (the did:web is derived from this).
FEEDGEN_HOSTNAME=feeds.coseeker.com
FEEDGEN_SERVICE_DID=did:web:feeds.coseeker.com

# DID of the account the feeds are published under (publisher.coseeker.org).
FEEDGEN_PUBLISHER_DID=did:plc:ieyfjh6ystyufa3a7pi3jw5q

# Persistent SQLite path (use :memory: only for throwaway local runs).
FEEDGEN_SQLITE_LOCATION=feed.sqlite

# Jetstream endpoint (filtered firehose). us-east / us-west, jetstream1 / 2.
FEEDGEN_SUBSCRIPTION_ENDPOINT=wss://jetstream2.us-east.bsky.network/subscribe

# Bind to localhost when fronted by a reverse proxy (Caddy); 0.0.0.0 otherwise.
FEEDGEN_LISTENHOST=127.0.0.1
FEEDGEN_PORT=3000

# Delay (ms) between firehose reconnect attempts.
FEEDGEN_SUBSCRIPTION_RECONNECT_DELAY=3000

# Auto-backfill a member's existing posts when they join a tracked list, so the
# feed isn't limited to posts seen live from the moment they joined. Set to
# false to disable (the initial bulk load is still done via `yarn backfill`).
FEEDGEN_AUTO_BACKFILL=true
# AppView used for auto-backfill author-feed reads.
FEEDGEN_APPVIEW=https://public.api.bsky.app
# Cap on posts auto-backfilled per newly added member (0 = unlimited).
FEEDGEN_BACKFILL_MAX_PER_AUTHOR=1000

# Optional, used only by `yarn publishAll` / `yarn publishFeed`. Do NOT commit a
# real value — leave it unset and you'll be prompted for an App Password.
# BLUESKY_APP_PASSWORD=
